[Library]
std = $MODEL_TECH/../std
ieee = $MODEL_TECH/../ieee
work = work

[vcom]
VHDL93 = 2008
Explicit = 1

[vsim]
Resolution = ps
UserTimeUnit = default
RunLength = 1 ns
IterationLimit = 5000
BreakOnAssertion = 2
DefaultRadix = symbolic
TranscriptFile = transcript
PathSeparator = /
DatasetSeparator = :
UnbufferedOutput = 0
ConcurrentFileLimit = 40

[Project]
